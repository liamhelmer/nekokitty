# Secrets and local configuration
.env
.env.*
!.env.example
*.pem
*.key
credentials*
secrets*

# Python, editors, and build products
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.idea/
.vscode/
build/
dist/
*.egg-info/

# Models, generated inference artifacts, and caches
models/
checkpoints/
*.safetensors
*.gguf
*.litertlm
*.onnx
*.engine
*.plan
*.pth
*.pt
*.bin
*.xnnpack_cache*
.cache/

# Private or generated sensor/user data
data/private/
recordings/
captures/
transcripts/
*.wav
*.flac
*.mp3
*.mp4
*.mkv
*.jpg
*.jpeg
*.png

# Reviewed third-party cat recordings are intentionally versioned with their
# per-file Creative Commons provenance. This exception must stay narrower than
# the private/generated media rules above.
!assets/cat-sounds/originals/*.wav
!assets/cat-sounds/originals/*.aiff
!assets/cat-sounds/originals/*.flac
!assets/cat-sounds/originals/*.mp3
!assets/cat-sounds/derived/*.wav

# Reviewed, deterministic story narration is generated media, but this exact
# versioned shelf is intentionally committed for offline playback.
!content/stories/recordings/
!content/stories/recordings/**/
!content/stories/recordings/**/*.json
!content/stories/recordings/**/*.flac

# Runtime state and diagnostics
*.log
*.pid
core
core.*
tmp/

# OS noise
.DS_Store
Thumbs.db
